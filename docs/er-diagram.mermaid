erDiagram
    USER {
        uuid id PK
        string first_name
        string last_name
        string email
        string password_hash
        string risk_profile
        timestamp registration_date
        timestamp last_access
    }
    MESSAGE {
        uuid id PK
        uuid receiver_id FK
        uuid sender_id FK
        text content
        timestamp date
    }
    PLATFORM {
        uuid id PK
        string name
        string type
    }
    USER_PLATFORM {
        uuid id PK
        uuid user_id FK
        uuid platform_id FK
        boolean active
        timestamp link_date
    }
    ASSET {
        uuid id PK
        string name
        string symbol
        string type
        decimal current_price
    }
    PORTFOLIO {
        uuid id PK
        uuid user_id FK
        string name
    }
    PORTFOLIO_ASSET {
        uuid id PK
        uuid portfolio_id FK
        uuid asset_id FK
        decimal quantity
        decimal average_price
    }
    TRANSACTION {
        uuid id PK
        uuid user_id FK
        uuid asset_id FK
        uuid platform_id FK
        string type
        decimal amount
        decimal quantity
        timestamp date
    }
    AI_DIAGNOSIS {
        uuid id PK
        uuid user_id FK
        string type
        text content
        timestamp date
    }
    COMMUNITY {
        uuid id PK
        uuid creator_id FK
        string name
        string description
        string type
        string logo_url
        timestamp creation_date
    }
    USER_COMMUNITY {
        uuid id PK
        uuid user_id FK
        uuid community_id FK
        string role
        timestamp join_date
    }
    TOPIC {
        uuid id PK
        uuid community_id FK
        string name
    }
    POST {
        uuid id PK
        uuid user_id FK
        uuid community_id FK
        string title
        text description
        string type
        timestamp date
    }
    COMMENT {
        uuid id PK
        uuid post_id FK
        uuid user_id FK
        text content
        timestamp date
    }
    LIKE {
        uuid id PK
        uuid post_id FK
        uuid user_id FK
        timestamp date
    }
    NEWS {
        uuid id PK
        string title
        string summary
        string url
        timestamp date
    }
    POST_NEWS {
        uuid post_id FK
        uuid news_id FK
    }
    FOLLOW {
        uuid id PK
        uuid follower_id FK
        uuid followed_id FK
        timestamp date
    }
    USER ||--o{ USER_PLATFORM : "links"
    PLATFORM ||--o{ USER_PLATFORM : "has"
    USER ||--o{ PORTFOLIO : "owns"
    PORTFOLIO ||--o{ PORTFOLIO_ASSET : "includes"
    ASSET ||--o{ PORTFOLIO_ASSET : "belongs to"
    USER ||--o{ TRANSACTION : "performs"
    ASSET ||--o{ TRANSACTION : "involves"
    PLATFORM ||--o{ TRANSACTION : "executed on"
    USER ||--o{ AI_DIAGNOSIS : "receives"
    USER ||--o{ COMMUNITY : "creates"
    USER ||--o{ USER_COMMUNITY : "joins"
    COMMUNITY ||--o{ USER_COMMUNITY : "groups"
    COMMUNITY ||--o{ TOPIC : "organizes"
    COMMUNITY ||--o{ POST : "contains"
    USER ||--o{ POST : "publishes"
    POST ||--o{ COMMENT : "receives"
    USER ||--o{ COMMENT : "comments"
    POST ||--o{ LIKE : "accumulates"
    USER ||--o{ LIKE : "gives"
    POST ||--o{ POST_NEWS : "attaches"
    NEWS ||--o{ POST_NEWS : "referenced in"
    USER ||--o{ FOLLOW : "follows"
    USER ||--o{ MESSAGE : "sends"